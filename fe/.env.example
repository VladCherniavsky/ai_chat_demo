# Cognito (optional for local dev — omit to run with dev bypass auth)
# From terraform: cognito_user_pool_id, cognito_client_id, cognito_domain
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=ai-chat-demo-dev.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_SCOPES=openid email profile

# OpenRouter (https://openrouter.ai/keys)
VITE_OPENROUTER_API_KEY=sk-or-...
VITE_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
